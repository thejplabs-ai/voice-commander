# Voice Commander — JP Labs
# Copie este arquivo para .env e preencha os valores:
#   copy .env.example .env

# ---------------------------------------------------------------------------
# Chave de Licença — obtida após pagamento em voice.jplabs.ai
# Formato: vc-{expiry_base64}-{hmac}
# ---------------------------------------------------------------------------
LICENSE_KEY=

# ---------------------------------------------------------------------------
# Google Gemini API Key — obter em https://aistudio.google.com/apikey
# Sem esta chave: transcrição pura funciona, mas sem correção/estruturação.
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------------------------------------------------------
# Modelo Gemini para correção/estruturação de texto
# Opções: gemini-2.5-flash (default, rápido) | gemini-2.5-pro (mais preciso, mais lento)
# ---------------------------------------------------------------------------
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Modelo Whisper para transcrição local (fallback global)
# Opções: tiny (default, rápido, <5s) | base | small | medium | large-v2 | large-v3
# Modelos maiores = maior precisão, mas mais lento e mais RAM.
# Use WHISPER_MODEL_FAST e WHISPER_MODEL_QUALITY para controle fino por modo.
# ---------------------------------------------------------------------------
WHISPER_MODEL=tiny

# ---------------------------------------------------------------------------
# Modelo Whisper para modos rápidos (transcribe, email, bullet, translate)
# Default: tiny — prioriza velocidade (<5s de latência)
# ---------------------------------------------------------------------------
WHISPER_MODEL_FAST=tiny

# ---------------------------------------------------------------------------
# Modelo Whisper para modos que exigem mais qualidade (simple, prompt, query)
# Default: small — melhor precisão para contextos complexos
# ---------------------------------------------------------------------------
WHISPER_MODEL_QUALITY=small

# ---------------------------------------------------------------------------
# Tempo máximo de gravação em segundos (default: 120)
# Um bip de aviso (600Hz) soa 5 segundos antes do timeout.
# ---------------------------------------------------------------------------
MAX_RECORD_SECONDS=120

# ---------------------------------------------------------------------------
# Índice do dispositivo de áudio (microfone)
# Deixe em branco para usar o dispositivo padrão do sistema.
# Para listar dispositivos disponíveis: python -c "import sounddevice; print(sounddevice.query_devices())"
# ---------------------------------------------------------------------------
AUDIO_DEVICE_INDEX=

# ---------------------------------------------------------------------------
# Hotkey para modo 4 (Query Direta Gemini)
# Default: ctrl+shift+alt+space (seguro no Windows 11)
# Alternativa: ctrl+win+space (testar conflito antes — conflita com Input Method no Win 11)
# ---------------------------------------------------------------------------
QUERY_HOTKEY=ctrl+shift+alt+space

# ---------------------------------------------------------------------------
# Prompt de sistema para o modo Query Direta
# Deixe em branco para usar o prompt padrão (assistente direto e preciso)
# ---------------------------------------------------------------------------
QUERY_SYSTEM_PROMPT=

# ---------------------------------------------------------------------------
# Idioma para transcrição Whisper
# Vazio = auto-detect (bilíngue PT+EN) | "pt" = forçar português | "en" = forçar inglês
# Forçar idioma reduz hallucinations, mas desativa auto-detect bilíngue.
# ---------------------------------------------------------------------------
WHISPER_LANGUAGE=

# ---------------------------------------------------------------------------
# Número máximo de entradas no histórico de transcrições (history.jsonl)
# ---------------------------------------------------------------------------
HISTORY_MAX_ENTRIES=500

# ---------------------------------------------------------------------------
# Número de sessões de log a manter (arquivos voice.YYYY-MM-DD_HH-MM-SS.log)
# ---------------------------------------------------------------------------
LOG_KEEP_SESSIONS=5

# ---------------------------------------------------------------------------
# Sensibilidade do filtro VAD (Voice Activity Detection) do Whisper
# Faixa: 0.1 (muito sensível) a 0.9 (pouco sensível) | Default: 0.3
# Se a transcrição falha com "Não entendi" e você está falando claramente,
# reduza este valor (ex: 0.2). Se transcreve ruídos de fundo, aumente (ex: 0.5).
# ---------------------------------------------------------------------------
VAD_THRESHOLD=0.3

# ---------------------------------------------------------------------------
# Prompt inicial para o Whisper (contexto de vocabulário e estilo de fala).
# Deixe vazio para usar o padrão PT-BR com termos técnicos em inglês.
# Para personalizar: inclua frases exemplo com os termos que você usa.
# Limite: ~224 tokens (~900 chars).
# ---------------------------------------------------------------------------
WHISPER_INITIAL_PROMPT=

# ---------------------------------------------------------------------------
# Provedor de IA — gemini (default) | openai
# ---------------------------------------------------------------------------
AI_PROVIDER=gemini

# ---------------------------------------------------------------------------
# OpenAI API Key — necessária apenas se AI_PROVIDER=openai
# Obter em: https://platform.openai.com/api-keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Provedor de STT (Speech-to-Text)
# "whisper" (default) — transcrição local, offline, funciona sem internet
# "gemini" — transcrição via Gemini API, superior em PT-BR + code-switching EN
#             Requer GEMINI_API_KEY. Whisper é fallback automático se Gemini falhar.
# ---------------------------------------------------------------------------
STT_PROVIDER=whisper

# ---------------------------------------------------------------------------
# Correção Gemini pós-Whisper — só relevante quando STT_PROVIDER=whisper
# "true" (default) — Gemini corrige erros do Whisper após transcrição
# "false" — retorna texto raw do Whisper sem passar pela correção
#           Útil para debug: isola se a correção está piorando ou melhorando
# ---------------------------------------------------------------------------
GEMINI_CORRECT=true

# ---------------------------------------------------------------------------
# Hotkey para ciclar entre modos
# Default: ctrl+shift+tab
# ---------------------------------------------------------------------------
CYCLE_HOTKEY=ctrl+shift+tab

# ---------------------------------------------------------------------------
# Modos incluídos no ciclo (Story 4.6.4) — separados por vírgula
# Default: 5 modos principais (visual e pipeline excluídos do ciclo — têm hotkey própria)
# Para incluir visual ou pipeline: CYCLE_MODES=transcribe,email,simple,prompt,query,visual,pipeline
# ---------------------------------------------------------------------------
CYCLE_MODES=transcribe,email,simple,prompt,query

# ---------------------------------------------------------------------------
# Overlay de feedback visual — toast no canto inferior direito
# "true" (default) — exibe estado Gravando/Processando/Pronto após hotkey
# "false" — desativa overlay (útil em modo headless ou se causar conflito)
# ---------------------------------------------------------------------------
OVERLAY_ENABLED=true

# ---------------------------------------------------------------------------
# Hotkey para abrir busca no histórico de transcrições
# Default: ctrl+shift+h | Overlay CTk com busca em tempo real + colar ao clicar
# ---------------------------------------------------------------------------
HISTORY_HOTKEY=ctrl+shift+h

# ---------------------------------------------------------------------------
# Clipboard Context (Story 4.5.4) — enriquece o modo Query com conteúdo do clipboard
# "true" (default) — no modo query, o texto copiado serve como contexto para o Gemini
# "false" — desativa; modo query funciona sem contexto de clipboard
# ---------------------------------------------------------------------------
CLIPBOARD_CONTEXT_ENABLED=true

# ---------------------------------------------------------------------------
# Limite de caracteres do clipboard enviados ao Gemini como contexto
# Default: 2000 chars (~300-400 palavras)
# ---------------------------------------------------------------------------
CLIPBOARD_CONTEXT_MAX_CHARS=2000

# ---------------------------------------------------------------------------
# Whisper beam size — trade-off velocidade vs precisão
# Faixa: 1 (mais rápido, menos preciso) a 10 (mais preciso, mais lento)
# Default: 1 (Story 4.6.1 — prioriza <5s de latência)
# Para maior precisão, use: WHISPER_BEAM_SIZE=5
# ---------------------------------------------------------------------------
WHISPER_BEAM_SIZE=1

# ---------------------------------------------------------------------------
# Delay adicional antes de colar texto (em milissegundos)
# Útil se o paste falha em aplicações mais lentas (ex: Notepad, Word)
# Default: 50ms (mais 500ms base = 550ms total antes do Ctrl+V)
# ---------------------------------------------------------------------------
PASTE_DELAY_MS=50

# ---------------------------------------------------------------------------
# Feature 1: User Profile — fatos sobre você injetados em todas as chamadas Gemini
# "false" (default) — desativado por padrão; ative quando quiser contexto pessoal
# "true" — Gemini recebe contexto do seu perfil em cada chamada
# Edite seu perfil em: Configurações > Perfil | Voz: "adiciona ao meu perfil: ..."
# ---------------------------------------------------------------------------
USER_PROFILE_ENABLED=false

# ---------------------------------------------------------------------------
# Feature 2: Active Window Context — enriquece chamadas com janela ativa
# "false" (default) — desativado por privacidade (título da janela não é enviado)
# "true" — Gemini recebe processo+título da janela ativa no início da gravação
# ---------------------------------------------------------------------------
WINDOW_CONTEXT_ENABLED=false

# ---------------------------------------------------------------------------
# Feature 3: Visual Query — screenshot + voz → Gemini multimodal
# Vazio (default) — desativado. Descomente para ativar:
# VISUAL_HOTKEY=ctrl+alt+shift+v
# O screenshot é enviado ao Gemini como contexto visual (nunca colado)
# ---------------------------------------------------------------------------
VISUAL_HOTKEY=

# ---------------------------------------------------------------------------
# Largura máxima do screenshot enviado ao Gemini (pixels, mantém aspect ratio)
# Default: 1280px. Reduza para 800 em redes lentas ou para economizar tokens.
# ---------------------------------------------------------------------------
SCREENSHOT_MAX_WIDTH=1280

# ---------------------------------------------------------------------------
# Feature 4: Briefing Matinal — resumo diário das suas transcrições via Gemini
# "false" (default) — desativado por padrão
# "true" — ativa; exibe popup com 3 bullet points ao iniciar o app às 8h
# Time gate: não repete por 8h após a última exibição.
# ---------------------------------------------------------------------------
BRIEFING_ENABLED=false

# ---------------------------------------------------------------------------
# Mínimo de entradas no histórico das últimas 24h para gerar briefing
# Default: 3. Se tiver menos transcrições hoje, o briefing é pulado.
# ---------------------------------------------------------------------------
BRIEFING_MIN_ENTRIES=3

# ---------------------------------------------------------------------------
# Feature 5: Pipeline Composto — clipboard + voz → transformações em cadeia
# Vazio (default) — desativado. Descomente para ativar:
# PIPELINE_HOTKEY=ctrl+alt+shift+p
# Fluxo: copie o texto → pressione hotkey → dite a instrução → resultado colado
# Exemplo: "resume em 2 bullets e traduz para inglês"
# ---------------------------------------------------------------------------
PIPELINE_HOTKEY=

# ---------------------------------------------------------------------------
# Máximo de caracteres do clipboard enviados ao Gemini no modo Pipeline
# Default: 8000 chars (~1200-1600 palavras)
# ---------------------------------------------------------------------------
PIPELINE_CLIPBOARD_MAX_CHARS=8000
